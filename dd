BASE_URL    = "https://ostol.onrender.com"  # رابط السيرفر
ADMIN_USER  = "admin"                  # اسم مستخدم أدمن
ADMIN_PASS  = "ad11228898"             # كلمة المرور
EXCEL_FILE  = "Book1.xlsx"             # مسار ملف Excel
# ══════════════════════════════════════════════


def fix_phone(phone):
    """تنظيف رقم التليفون وتوحيد صيغته"""
    if not phone or str(phone).strip() in ('', 'nan'):
        return ""
    p = re.sub(r'\D', '', str(phone))
    if len(p) == 10 and not p.startswith('0'):
        p = '0' + p
    return p


def fix_date(val):
    """تحويل التاريخ إلى صيغة YYYY-MM-DD"""
    if not val or str(val).strip() in ('', 'nan', 'NaT'):
        return ""
    s = str(val).strip()
    # pandas Timestamp
    if hasattr(val, 'strftime'):
        return val.strftime('%Y-%m-%d')
    # صيغة YYYY/M/D أو YYYY-M-D
    m = re.match(r'(\d{4})[/-](\d{1,2})[/-](\d{1,2})', s)
    if m:
        y, mo, d = m.groups()
        if int(y) > 2000:
            return f"{y}-{int(mo):02d}-{int(d):02d}"
    return ""


def make_username(name, fixed_num):
    """توليد username من الاسم أو الرقم الثابت"""
    if fixed_num:
        return f"drv_{str(fixed_num).strip()}"
    clean = re.sub(r'\s+', '_', name.strip().lower())
    clean = re.sub(r'[^\w]', '', clean)
    return f"drv_{clean}"


def make_password(fixed_num, phone):
    """كلمة مرور افتراضية = الرقم الثابت أو آخر 6 أرقام من التليفون"""
    if fixed_num and str(fixed_num).strip():
        return str(fixed_num).strip()
    ph = fix_phone(phone)
    return ph[-6:] if len(ph) >= 6 else "123456"


def login(session):
    r = session.post(f"{BASE_URL}/auth/login",
                     json={"username": ADMIN_USER, "password": ADMIN_PASS})
    if r.status_code != 200:
        print(f"❌ فشل تسجيل الدخول: {r.text}")
        sys.exit(1)
    token = r.json().get("access_token")
    session.headers.update({"Authorization": f"Bearer {token}"})
    print(f"✅ تم تسجيل الدخول كـ {ADMIN_USER}")


def load_excel(path):
    df = pd.read_excel(path, header=None)
    # إيجاد صف الـ header (السطر اللي فيه "اسم السائق")
    header_row = None
    for i, row in df.iterrows():
        if any("اسم السائق" in str(c) for c in row.values):
            header_row = i
            break
    if header_row is None:
        print("❌ مش لاقي عمود 'اسم السائق' في الملف")
        sys.exit(1)
    df = pd.read_excel(path, header=header_row)
    # إزالة الأعمدة الفاضية
    df = df.dropna(how='all', axis=1).dropna(how='all', axis=0)
    # توحيد أسماء الأعمدة
    col_map = {}
    for c in df.columns:
        cs = str(c).strip()
        if 'اسم السائق' in cs:     col_map[c] = 'name'
        elif 'رقم ثابت' in cs:     col_map[c] = 'fixed_number'
        elif 'تليفون' in cs:       col_map[c] = 'phone'
        elif 'رخصة السيارة' in cs: col_map[c] = 'vehicle_license_expiry'
        elif 'رخصة السائق' in cs:  col_map[c] = 'driver_license_expiry'
    df = df.rename(columns=col_map)
    needed = ['name']
    for n in needed:
        if n not in df.columns:
            print(f"❌ العمود '{n}' مش موجود في الملف")
            sys.exit(1)
    df = df[df['name'].notna() & (df['name'].astype(str).str.strip() != '')]
    return df


def import_drivers(session, df):
    success, skipped, errors = 0, 0, 0
    used_usernames = set()

    # جلب السائقين الموجودين مسبقاً
    existing = session.get(f"{BASE_URL}/drivers").json()
    existing_fixed = {str(d.get('fixed_number','')) for d in existing if d.get('fixed_number')}
    print(f"📋 سائقون موجودون مسبقاً: {len(existing)}")
    print(f"📄 سائقون في الملف: {len(df)}")
    print("─" * 55)

    for _, row in df.iterrows():
        name         = str(row.get('name', '')).strip()
        fixed_num    = str(row.get('fixed_number', '')).strip().replace('.0','')
        phone        = fix_phone(row.get('phone', ''))
        drv_lic      = fix_date(row.get('driver_license_expiry', ''))
        veh_lic      = fix_date(row.get('vehicle_license_expiry', ''))

        if not name:
            continue

        # تخطي المكرر بالرقم الثابت
        if fixed_num and fixed_num in existing_fixed:
            print(f"⏭️  موجود مسبقاً: {name} ({fixed_num})")
            skipped += 1
            continue

        # توليد username فريد
        base_uname = make_username(name, fixed_num)
        uname = base_uname
        counter = 2
        while uname in used_usernames:
            uname = f"{base_uname}_{counter}"; counter += 1
        used_usernames.add(uname)

        password = make_password(fixed_num, phone)

        payload = {
            "name":                    name,
            "phone":                   phone,
            "username":                uname,
            "password":                password,
            "status":                  "active",
            "fixed_number":            fixed_num,
            "driver_license_expiry":   drv_lic,
            "vehicle_license_expiry":  veh_lic,
            "national_id":             "",
            "birth_date":              "",
            "branch":                  ""
        }

        r = session.post(f"{BASE_URL}/drivers", json=payload)
        if r.status_code in (200, 201):
            print(f"✅ {name:<30} | user: {uname:<25} | pass: {password}")
            success += 1
            if fixed_num:
                existing_fixed.add(fixed_num)
        elif r.status_code == 400 and "موجود" in r.text:
            print(f"⚠️  مكرر:   {name} — {r.json().get('detail','')}")
            skipped += 1
        else:
            print(f"❌ خطأ:    {name} — {r.status_code}: {r.text[:80]}")
            errors += 1

    print("─" * 55)
    print(f"✅ تم إضافة : {success}")
    print(f"⏭️  تم تخطي : {skipped} (موجودون مسبقاً)")
    print(f"❌ أخطاء    : {errors}")
    print("─" * 55)
    if success:
        print("💡 كلمة مرور كل سائق = رقمه الثابت")
        print("   (مثال: رقم ثابت 178058 → كلمة المرور 178058)")


def main():
    print("=" * 55)
    print("  🚗 استيراد السائقين — نظام إدارة الأسطول")
    print("=" * 55)
    s = requests.Session()
    login(s)
    df = load_excel(EXCEL_FILE)
    import_drivers(s, df)


if __name__ == "__main__":
    main()
